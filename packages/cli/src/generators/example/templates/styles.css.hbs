:root {
  --background-color: #1b1b1f;
  --background-accent-color: #161618;
  --color: #dfdfd6;
  --link-color: #1f718f;
  font-family: sans-serif;
  font-size: 16px;
  color: var(--color);
  background-color: var(--background-color);
}

* {
  box-sizing: border-box;
}

html,
body {
  margin: 0;
  min-height: 100vh;
}
